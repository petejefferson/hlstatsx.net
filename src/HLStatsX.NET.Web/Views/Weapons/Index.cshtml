@model WeaponListViewModel
@{
    ViewData["Title"] = "Weapons";

    string SortUrl(string field)
    {
        bool nextDesc = Model.SortBy == field ? !Model.Descending : true;
        return Url.Action("Index", new { game = Model.Game, sortBy = field, desc = nextDesc })!;
    }
    string Mark(string field) => Model.SortBy == field ? (Model.Descending ? " ▼" : " ▲") : "";
}

<h1>Weapons &mdash; @Model.Game</h1>

<table class="stats-table">
    <thead>
        <tr>
            <th>Rank</th>
            <th>Weapon</th>
            <th><a href="@(SortUrl("kills"))">Kills@(Mark("kills"))</a></th>
            <th><a href="@(SortUrl("headshots"))">Headshots@(Mark("headshots"))</a></th>
            <th><a href="@(SortUrl("hspct"))">HS%@(Mark("hspct"))</a></th>
        </tr>
    </thead>
    <tbody>
        @{ int rank = (Model.Weapons.Page - 1) * Model.Weapons.PageSize + 1; }
        @foreach (var w in Model.Weapons.Items)
        {
            <tr>
                <td>@rank</td>
                <td><a asp-action="Detail" asp-route-id="@w.WeaponId">@w.Name</a></td>
                <td>@w.Kills</td>
                <td>@w.Headshots</td>
                <td>@w.HeadshotPercent%</td>
            </tr>
            rank++;
        }
    </tbody>
</table>

<partial name="_Pagination" model="@PaginationModel.From(Model.Weapons, p => Url.Action("Index", new { game = Model.Game, sortBy = Model.SortBy, desc = Model.Descending, page = p })!)" />
