@model AdminUserListViewModel
@{
    ViewData["Title"] = "Admin Users";
    Layout = "_AdminLayout";
}

<h1>Admin Users</h1>
<p><a href="/Admin/Users/Create" class="btn btn-primary">Add User</a></p>

<table class="admin-table">
    <thead><tr><th>Username</th><th>Access Level</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var u in Model.Users)
    {
        <tr>
            <td>@u.Username</td>
            <td>@u.AccLevel@(u.AccLevel >= 100 ? " (Admin)" : u.AccLevel >= 80 ? " (Restricted)" : " (None)")</td>
            <td>
                <a href="/Admin/Users/Edit/@u.Username" class="btn btn-secondary btn-sm">Edit</a>
                <form asp-action="DeleteUser" asp-route-username="@u.Username" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm"
                            onclick="return confirm('Delete user @u.Username?')">Delete</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Users.Any()) { <tr><td colspan="3">No admin users.</td></tr> }
    </tbody>
</table>
