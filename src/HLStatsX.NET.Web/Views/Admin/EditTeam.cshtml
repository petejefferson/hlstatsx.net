@model HLStatsX.NET.Core.Entities.Team
@{ Layout = "_AdminLayout"; var id = ViewContext.RouteData.Values["id"]?.ToString() ?? "0"; }
<h1>@ViewData["Title"]</h1>
<form asp-action="EditTeam" asp-route-id="@id" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Game" type="hidden" />
    <div class="form-group"><label asp-for="Code">Team Code</label><input asp-for="Code" type="text" maxlength="32" /></div>
    <div class="form-group"><label asp-for="Name">Team Name</label><input asp-for="Name" type="text" maxlength="64" /></div>
    <div class="form-group"><label asp-for="PlayerlistColor">Text Color (hex)</label><input asp-for="PlayerlistColor" type="text" maxlength="7" /></div>
    <div class="form-group"><label asp-for="PlayerlistBgcolor">Background Color (hex)</label><input asp-for="PlayerlistBgcolor" type="text" maxlength="7" /></div>
    <div class="form-group">
        <input type="hidden" name="Hidden" value="0" />
        <label><input type="checkbox" name="Hidden" value="1" @(Model.Hidden == "1" ? "checked" : "") /> Hide team</label>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Teams?game=@Model.Game" class="btn btn-secondary" style="margin-left:8px;">Cancel</a>
    </div>
</form>
