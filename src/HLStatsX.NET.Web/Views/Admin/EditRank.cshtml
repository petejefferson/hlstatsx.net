@model HLStatsX.NET.Core.Entities.Rank
@{ Layout = "_AdminLayout"; var id = ViewContext.RouteData.Values["id"]?.ToString() ?? "0"; }
<h1>@ViewData["Title"]</h1>
<form asp-action="EditRank" asp-route-id="@id" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Game" type="hidden" />
    <div class="form-group"><label asp-for="RankName">Rank Name</label><input asp-for="RankName" type="text" maxlength="50" /></div>
    <div class="form-group"><label asp-for="MinKills">Minimum Kills</label><input asp-for="MinKills" type="number" style="width:100px;" /></div>
    <div class="form-group"><label asp-for="MaxKills">Maximum Kills</label><input asp-for="MaxKills" type="number" style="width:100px;" /></div>
    <div class="form-group"><label asp-for="Image">Image filename</label><input asp-for="Image" type="text" maxlength="30" /></div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Ranks?game=@Model.Game" class="btn btn-secondary" style="margin-left:8px;">Cancel</a>
    </div>
</form>
