@model CreateAdminUserViewModel
@{
    ViewData["Title"] = "Create Admin User";
}

<h1>Create Admin User</h1>

<div class="login-box" style="margin-top:1rem;">
    <form asp-action="CreateUser" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="error-list"></div>

        <div class="form-group">
            <label asp-for="Username">Username</label>
            <input asp-for="Username" class="form-control" autocomplete="off" />
            <span asp-validation-for="Username" class="error-list"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Password</label>
            <input asp-for="Password" class="form-control" type="password" />
            <span asp-validation-for="Password" class="error-list"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" />
            <span asp-validation-for="ConfirmPassword" class="error-list"></span>
        </div>

        <div class="form-group">
            <label asp-for="AccLevel">Access Level</label>
            <input asp-for="AccLevel" class="form-control" type="number" min="1" max="100" />
            <span asp-validation-for="AccLevel" class="error-list"></span>
        </div>

        <button type="submit" class="btn-primary">Create User</button>
        <a asp-action="Users" style="margin-left:1rem;">Cancel</a>
    </form>
</div>
