@model CreateAdminUserViewModel
@{
    ViewData["Title"] = "Create Admin User";
    Layout = "_AdminLayout";
}

<h1>Create Admin User</h1>

<form asp-action="CreateUser" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert-danger"></div>
    <div class="form-group">
        <label asp-for="Username">Username</label>
        <input asp-for="Username" type="text" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ConfirmPassword">Confirm Password</label>
        <input asp-for="ConfirmPassword" type="password" />
    </div>
    <div class="form-group">
        <label asp-for="AccLevel">Access Level (1-100; 80=Restricted, 100=Admin)</label>
        <input asp-for="AccLevel" type="number" min="1" max="100" style="width:80px;" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create User</button>
        <a href="/Admin/Users" class="btn btn-secondary" style="margin-left:8px;">Cancel</a>
    </div>
</form>
