@model IReadOnlyList<Server>
@{
    ViewData["Title"] = "Manage Servers";
}

<h1>Manage Servers</h1>

<table class="stats-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Game</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.Address:@s.Port</td>
                <td>@s.Game</td>
                <td>@(s.IsActive ? "Active" : "Inactive")</td>
                <td>
                    <form asp-action="DeleteServer" asp-route-id="@s.ServerId" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary" style="font-size:0.8rem;padding:0.2rem 0.6rem;"
                                onclick="return confirm('Delete server @s.Name?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="5">No servers configured.</td></tr>
        }
    </tbody>
</table>

<p><a asp-action="Dashboard">&larr; Dashboard</a></p>
