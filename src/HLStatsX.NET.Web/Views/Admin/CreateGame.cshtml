@model GameFormViewModel
@using HLStatsX.NET.Core.Entities
@{
    Layout = "_AdminLayout";
    var supported = ViewData["SupportedGames"] as IReadOnlyList<GameSupported> ?? new List<GameSupported>();
}

<h1>@ViewData["Title"]</h1>

<form asp-action="CreateGame" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert-danger"></div>
    <div class="form-group">
        <label asp-for="Code">Game Code (mod folder name, e.g. "dods")</label>
        <input asp-for="Code" type="text" />
    </div>
    <div class="form-group">
        <label asp-for="Name">Display Name</label>
        <input asp-for="Name" type="text" />
    </div>
    <div class="form-group">
        <label asp-for="RealGame">Based on (engine type)</label>
        <select asp-for="RealGame">
            <option value="">-- select --</option>
            @foreach (var g in supported)
            {
                <option value="@g.Code">@g.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label><input asp-for="Hidden" type="checkbox" /> Hide this game from public listings</label>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Add Game</button>
        <a href="/Admin/Games" class="btn btn-secondary" style="margin-left:8px;">Cancel</a>
    </div>
</form>
