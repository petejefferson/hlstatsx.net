@model GameFormViewModel
@using HLStatsX.NET.Core.Entities
@{
    Layout = "_AdminLayout";
    var supported = ViewData["SupportedGames"] as IReadOnlyList<GameSupported> ?? new List<GameSupported>();
    var code = ViewContext.RouteData.Values["code"]?.ToString() ?? string.Empty;
}

<h1>@ViewData["Title"]</h1>

<form asp-action="EditGame" asp-route-code="@code" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label>Game Code</label>
        <input type="text" value="@Model.Code" readonly style="background:#eee;width:200px;" />
    </div>
    <div class="form-group">
        <label asp-for="Name">Display Name</label>
        <input asp-for="Name" type="text" />
    </div>
    <div class="form-group">
        <label asp-for="RealGame">Based on (engine type)</label>
        <select asp-for="RealGame">
            <option value="">-- select --</option>
            @foreach (var g in supported)
            {
                <option value="@g.Code" selected="@(g.Code == Model.RealGame ? "selected" : null)">@g.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label><input asp-for="Hidden" type="checkbox" /> Hide this game</label>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Games" class="btn btn-secondary" style="margin-left:8px;">Cancel</a>
    </div>
</form>
