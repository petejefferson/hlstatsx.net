@model EditDetailsSearchViewModel
@{
    ViewData["Title"] = "Edit Player/Clan";
    Layout = "_AdminLayout";
}

<h1>Edit Player or Clan Details</h1>

<form method="get" asp-action="EditDetails">
    <div class="form-group">
        <label>Search by player or clan ID, or name:</label>
        <input type="text" name="query" value="@Model.Query" style="width:300px;" placeholder="Enter name or numeric ID" />
        <select name="type" style="margin-left:8px;">
            <option value="" selected="@(string.IsNullOrEmpty(Model.Type) ? "selected" : null)">Players &amp; Clans</option>
            <option value="player" selected="@(Model.Type=="player" ? "selected" : null)">Players only</option>
            <option value="clan" selected="@(Model.Type=="clan" ? "selected" : null)">Clans only</option>
        </select>
        <button type="submit" class="btn btn-primary" style="margin-left:8px;">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Query) && int.TryParse(Model.Query, out var numId))
{
    <p>
        @if (Model.Type != "clan")
        {
            <a href="/Admin/Tools/EditPlayer/@numId" class="btn btn-secondary">Edit Player #@numId</a>
        }
        @if (Model.Type != "player")
        {
            <a href="/Admin/Tools/EditClan/@numId" class="btn btn-secondary" style="margin-left:8px;">Edit Clan #@numId</a>
        }
    </p>
}
