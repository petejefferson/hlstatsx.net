          <th style="text-align:right"><a href="@(SpSortUrl("headshots"))">Headshots@(SpMark("headshots"))</a></th>
          <th><a href="@(SpSortUrl("hpercent"))">Ratio@(SpMark("hpercent"))</a></th>
