            <td class="@spRow"><meter min="0" max="100" low="25" high="50" optimum="75" value="@(spKpct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"></meter></td>
            <td class="@spAlt" style="text-align:right">@s.Deaths.ToString("N0")</td>
            <td class="@spRow" style="text-align:right">@spKpd.ToString("F2")</td>
            <td class="@spAlt" style="text-align:right">@s.Headshots.ToString("N0")</td>
            <td class="@spRow"><meter min="0" max="100" low="25" high="50" optimum="75" value="@(spHpct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"></meter></td>
            <td class="@spAlt" style="text-align:right">@(spHpct.ToString("F2"))%</td>
            <td class="@spRow" style="text-align:right">@(s.Kills == 0 ? "-" : spHpk.ToString("F2"))</td>
          </tr>
          spRank++;
        }
      </tbody>
    </table>
    <br />
  }

  @if (!Model.MapPerformance.Any() && !Model.ServerPerformance.Any())
  {
    <p>No map or server data available.</p>
  }
</div>

<div id="tab-kills" class="tab-panel" style="display:none;">
  <h2>Kill Statistics *</h2>
  @if (!Model.KillStats.Any())
  {
    <p>No kill stat data available (minimum 5 kills against a single player).</p>
  }
  else
  {
    long ksTotalKills = Model.KillStats.Sum(k => k.Kills);
    long ksTotalDeaths = Model.KillStats.Sum(k => k.Deaths);
    long ksTotalHS = Model.KillStats.Sum(k => k.Headshots);
    <table class="stats-table">
      <thead>
        <tr>
          <th>Victim</th>
          <th>Kills</th><th>%</th>
          <th>Deaths</th><th>%</th>
          <th>K:D</th>
          <th>Headshots</th><th>%</th><th>HS:K</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var k in Model.KillStats)
        {
          <tr>
            <td>
              @if (k.VictimIsBot && Model.HideBotPlayers)
              {
                  @k.VictimName
              }
              else
              {
                  <a asp-action="Profile" asp-route-id="@k.VictimId">@k.VictimName</a>
              }
            </td>
            <td>@k.Kills.ToString("N0")</td>
            <td>@(ksTotalKills > 0 ? $"{(double)k.Kills / ksTotalKills * 100:F2}%" : "-")</td>
            <td>@k.Deaths.ToString("N0")</td>
            <td>@(ksTotalDeaths > 0 ? $"{(double)k.Deaths / ksTotalDeaths * 100:F2}%" : "-")</td>
            <td>@(k.Deaths == 0 ? k.Kills.ToString("N0") : $"{(double)k.Kills / k.Deaths:F2}")</td>
            <td>@k.Headshots.ToString("N0")</td>
            <td>@(ksTotalHS > 0 ? $"{(double)k.Headshots / ksTotalHS * 100:F2}%" : "-")</td>
            <td>@(k.Kills == 0 ? "-" : $"{(double)k.Headshots / k.Kills:F2}")</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<div style="clear:both;padding-top:12px;display:flex;justify-content:space-between;">
  <div>Items marked &ldquo;*&rdquo; above are generated from the last @Model.DeleteDays days.</div>
  <div>Go to: <a asp-controller="Players" asp-action="Index" asp-route-game="@Model.Player.Game">Player Rankings</a></div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
document.querySelectorAll('.tab-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
        e.preventDefault();
        document.querySelectorAll('.tab-link').forEach(function(l) { l.classList.remove('active'); });
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.style.display = 'none'; });
        this.classList.add('active');
        document.querySelector(this.getAttribute('href')).style.display = 'block';
    });
});

@if (Model.TrendData.Count >= 2)
{
    var labels   = Model.TrendData.Select(t => t.EventTime.ToString("MMM-d")).ToArray();
    var skills   = Model.TrendData.Select(t => (double)t.Skill / 1000.0).ToArray();
    var sessions = Model.TrendData.Select(t => (double)t.SkillChange).ToArray();

    <text>
(function() {
    var ctx = document.getElementById('trendChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels)),
            datasets: [
                {
                    label: 'Skill',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(skills)),
                    borderColor: 'rgb(255, 255, 0)',
                    backgroundColor: 'rgba(255, 255, 0, 0.1)',
                    tension: 0.4,
                    yAxisID: 'ySkill'
                },
                {
                    label: 'Session',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessions)),
                    borderColor: 'rgb(255, 80, 80)',
                    backgroundColor: 'rgba(255, 80, 80, 0.1)',
                    tension: 0.4,
                    yAxisID: 'ySession'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { labels: { color: '#ddd', usePointStyle: true, pointStyle: 'line' } } },
            scales: {
                ySkill: {
                    type: 'linear', position: 'right',
                    ticks: { color: '#ddd', callback: function(v) { return v + 'K'; } },
                    grid: { color: '#444' },
                    title: { display: true, text: 'Skill', color: '#ddd' }
                },
                ySession: {
                    type: 'linear', position: 'left',
                    ticks: { color: '#ddd' },
                    grid: { color: '#333' },
                    title: { display: true, text: 'Session', color: '#ddd' }
                },
                x: {
                    ticks: { color: '#ddd', autoSkip: true, maxTicksLimit: 8, maxRotation: 45, minRotation: 0 },
                    grid: { color: '#333' },
                    title: { display: true, text: 'Date', color: '#ddd' }
                }
            }
        }
    });
})();
    </text>
}

// Forum signature text switcher
var sigImgUrl  = '@sigAbsUrl';
var profileUrl = '@profileAbsUrl';
function setSigText(mode) {
    var ta = document.getElementById('siglink');
    if (!ta) return;
    if (mode === 0) { ta.value = sigImgUrl; }
    else if (mode === 1) { ta.value = '[url=' + profileUrl + '][img]' + sigImgUrl + '[/img][/url]'; }
    else if (mode === 2) { ta.value = '[url="' + profileUrl + '"][img]' + sigImgUrl + '[/img][/url]'; }
    ta.select();
}
</script>
}
