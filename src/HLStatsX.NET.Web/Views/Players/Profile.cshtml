<div id="tab-maps" class="tab-panel" style="display:none;">
@{
    string MpSortUrl(string field)
    {
        bool nextDesc = Model.MapSortBy == field ? !Model.MapDesc : true;
        return Url.Action("Profile", new { id = Model.Player.PlayerId,
            mpSort = field, mpDesc = nextDesc,
            spSort = Model.ServerSortBy, spDesc = Model.ServerDesc,
            wuSort = Model.WeaponUsageSortBy,   wuDesc = Model.WeaponUsageDesc,
            wsSort = Model.WeaponStatsmeSortBy, wsDesc = Model.WeaponStatsmeDesc,
            wtSort = Model.WeaponTargetSortBy,  wtDesc = Model.WeaponTargetDesc })! + "#tab-maps";
    }
    string MpMark(string field) => Model.MapSortBy == field ? (Model.MapDesc ? " ▼" : " ▲") : "";

    string SpSortUrl(string field)
    {
        bool nextDesc = Model.ServerSortBy == field ? !Model.ServerDesc : true;
        return Url.Action("Profile", new { id = Model.Player.PlayerId,
            mpSort = Model.MapSortBy, mpDesc = Model.MapDesc,
            spSort = field, spDesc = nextDesc,
            wuSort = Model.WeaponUsageSortBy,   wuDesc = Model.WeaponUsageDesc,
            wsSort = Model.WeaponStatsmeSortBy, wsDesc = Model.WeaponStatsmeDesc,
            wtSort = Model.WeaponTargetSortBy,  wtDesc = Model.WeaponTargetDesc })! + "#tab-maps";
    }
    string SpMark(string field) => Model.ServerSortBy == field ? (Model.ServerDesc ? " ▼" : " ▲") : "";
}

  @* ── Map Performance ── *@
  @if (Model.MapPerformance.Any())
  {
    long mpRealKills  = Model.RealStats.RealKills  > 0 ? Model.RealStats.RealKills  : 1;
    long mpRealDeaths = Model.RealStats.RealDeaths > 0 ? Model.RealStats.RealDeaths : 1;
    long mpRealHS     = Model.RealStats.RealHeadshots > 0 ? Model.RealStats.RealHeadshots : 1;
    <h2>Map Performance *</h2>
    <table class="data-table">
      <thead>
        <tr class="data-table-head">
          <th>Rank</th>
          <th><a href="@(MpSortUrl("map"))">Map@(MpMark("map"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("kills"))">Kills@(MpMark("kills"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("kpercent"))">%@(MpMark("kpercent"))</a></th>
          <th><a href="@(MpSortUrl("kpercent"))">Ratio@(MpMark("kpercent"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("deaths"))">Deaths@(MpMark("deaths"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("dpercent"))">%@(MpMark("dpercent"))</a></th>
          <th><a href="@(MpSortUrl("dpercent"))">Ratio@(MpMark("dpercent"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("kpd"))">K:D@(MpMark("kpd"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("headshots"))">Headshots@(MpMark("headshots"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("hpercent"))">%@(MpMark("hpercent"))</a></th>
          <th><a href="@(MpSortUrl("hpercent"))">Ratio@(MpMark("hpercent"))</a></th>
          <th style="text-align:right"><a href="@(MpSortUrl("hpk"))">HS:K@(MpMark("hpk"))</a></th>
        </tr>
      </thead>
      <tbody>
        @{int mpRank = 1; bool mpBg = false;}
        @foreach (var m in Model.MapPerformance)
        {
          string mpRow = mpBg ? "bg2" : "bg1"; mpBg = !mpBg;
          string mpAlt = mpBg ? "bg2" : "bg1";
          double mpKpct = Math.Round((double)m.Kills  / mpRealKills  * 100, 2);
          double mpDpct = Math.Round((double)m.Deaths / mpRealDeaths * 100, 2);
          double mpHpct = Math.Round((double)m.Headshots / mpRealHS  * 100, 2);
          double mpKpd  = m.Deaths == 0 ? m.Kills : Math.Round((double)m.Kills / m.Deaths, 2);
          double mpHpk  = m.Kills  == 0 ? 0       : Math.Round((double)m.Headshots / m.Kills, 2);
          <tr>
            <td class="@mpRow" style="text-align:right">@mpRank</td>
            <td class="@mpAlt">@m.Map</td>
            <td class="@mpRow" style="text-align:right">@m.Kills.ToString("N0")</td>
            <td class="@mpAlt" style="text-align:right">@(mpKpct.ToString("F2"))%</td>
            <td class="@mpRow"><meter min="0" max="100" low="25" high="50" optimum="75" value="@(mpKpct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"></meter></td>
            <td class="@mpAlt" style="text-align:right">@m.Deaths.ToString("N0")</td>
            <td class="@mpRow" style="text-align:right">@(mpDpct.ToString("F2"))%</td>
            <td class="@mpAlt"><meter min="0" max="100" low="25" high="50" optimum="75" value="@(mpDpct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"></meter></td>
            <td class="@mpRow" style="text-align:right">@mpKpd.ToString("F2")</td>
            <td class="@mpAlt" style="text-align:right">@m.Headshots.ToString("N0")</td>
            <td class="@mpRow" style="text-align:right">@(mpHpct.ToString("F2"))%</td>
            <td class="@mpAlt"><meter min="0" max="100" low="25" high="50" optimum="75" value="@(mpHpct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"></meter></td>
            <td class="@mpRow" style="text-align:right">@(m.Kills == 0 ? "-" : mpHpk.ToString("F2"))</td>
          </tr>
          mpRank++;
        }
      </tbody>
    </table>
    <br />
  }

  @* ── Server Activity ── *@
