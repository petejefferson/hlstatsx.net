@model PlayerProfileViewModel
@using HLStatsX.NET.Core.Models
@{
    ViewData["Title"] = Model.Player.LastName;

    string FormatTime(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        var parts = new List<string>();
        if (ts.Days > 0) parts.Add($"{ts.Days} day{(ts.Days != 1 ? "s" : "")}");
        if (ts.Hours > 0) parts.Add($"{ts.Hours} hour{(ts.Hours != 1 ? "s" : "")}");
        if (ts.Minutes > 0) parts.Add($"{ts.Minutes} minute{(ts.Minutes != 1 ? "s" : "")}");
        return parts.Count > 0 ? string.Join(", ", parts) : "0 minutes";
    }

    var scheme       = Context.Request.Scheme;
    var sigAbsUrl    = Url.Action("Sig",     "Players", new { id = Model.Player.PlayerId }, scheme)!;
    var profileAbsUrl = Url.Action("Profile", "Players", new { id = Model.Player.PlayerId }, scheme)!;
    var defaultSigText = $"[url={profileAbsUrl}][img]{sigAbsUrl}[/img][/url]";
}

<h1>
    @if (!string.IsNullOrEmpty(Model.Player.Flag))
    {
        <img src="/hlstatsimg/flags/@(Model.Player.Flag.ToLower()).gif" alt="@Model.Player.Country" title="@Model.Player.Country" style="vertical-align:middle;" />
    }
    @Model.Player.LastName
    <small class="text-muted">&mdash; #@Model.Rank @if (Model.CurrentRank != null) { <span>(@Model.CurrentRank.RankName)</span> }</small>
</h1>

<div class="profile-tabs" id="profileTabs">
    <a href="#tab-general" class="tab-link active">General</a>
    <a href="#tab-aliases" class="tab-link">Aliases</a>
    <a href="#tab-teams" class="tab-link">Teams &amp; Actions</a>
    <a href="#tab-weapons" class="tab-link">Weapons</a>
    <a href="#tab-maps" class="tab-link">Maps &amp; Servers</a>
    <a href="#tab-kills" class="tab-link">Kill Stats</a>
</div>

<div id="tab-general" class="tab-panel active">
  <div class="profile-two-col">
    <section class="profile-card">
      <h2>Player Profile</h2>
      <table class="stats-table">
        <tr><th>Name</th><td><strong>@Model.Player.LastName</strong></td></tr>
        <tr>
          <th>Location</th>
          <td>
            @if (!string.IsNullOrEmpty(Model.Player.Country))
            {
                @if (!string.IsNullOrEmpty(Model.Player.City)) { <text>@Model.Player.City, </text> }
                @Model.Player.Country
            }
            else { <text>(Unknown)</text> }
          </td>
        </tr>
        @{
            var steamId = Model.Player.UniqueIds.FirstOrDefault()?.UniqueId;
        }
        @if (steamId != null)
        {
        <tr><th>Steam ID</th><td><code>@steamId</code></td></tr>
        }
        <tr><th>Karma</th><td>
            @if (Model.Player.HideRanking == 2) { <span class="text-danger"><strong>Banned</strong></span> }
            else { <span class="text-success"><strong>In good standing</strong></span> }
        </td></tr>
        @if (Model.Player.Clan is not null)
        {
        <tr><th>Clan</th><td><a asp-controller="Clans" asp-action="Profile" asp-route-id="@Model.Player.Clan.ClanId">@Model.Player.Clan.Name</a></td></tr>
        }
        @if (!string.IsNullOrEmpty(Model.Player.FullName))
        {
        <tr><th>Real Name</th><td><strong>@Model.Player.FullName</strong></td></tr>
        }
        @if (!string.IsNullOrEmpty(Model.Player.Homepage))
        {
        <tr><th>Home Page</th><td><a href="@Model.Player.Homepage" rel="nofollow noopener" target="_blank">@Model.Player.Homepage</a></td></tr>
        }
        <tr><th>Last Connect</th><td>@(Model.LastConnect.HasValue ? Model.LastConnect.Value.ToString("ddd. MMM. d, yyyy @ HH:mm:ss") : "(Unknown)")</td></tr>
        <tr><th>Connection Time</th><td>@FormatTime(Model.Player.ConnectionTime)</td></tr>
        <tr><th>Average Ping</th><td>
            @if (Model.Ping != null) { <text>@Model.Ping.AvgPing ms (Latency: @Model.Ping.AvgLatency ms)</text> }
            else { <text>-</text> }
        </td></tr>
        <tr><th>Favorite Server</th><td>
            @if (Model.FavoriteServer != null) { <a asp-controller="Servers" asp-action="Detail" asp-route-id="@Model.FavoriteServer.ServerId">@Model.FavoriteServer.ServerName</a> }
            else { <text>-</text> }
        </td></tr>
        <tr><th>Favorite Map</th><td>@(Model.FavoriteMap ?? "-")</td></tr>
        <tr><th>Favorite Weapon</th><td>
            @if (Model.FavoriteWeapon != null) { <text>@Model.FavoriteWeapon.WeaponName</text> }
            else { <text>-</text> }
        </td></tr>
      </table>
    </section>

    <section class="profile-stats-summary">
      <h2>Statistics Summary</h2>
      <table class="stats-table">
        <tr>
          <th>Activity</th>
          <td>
            <meter min="0" max="100" low="25" high="50" optimum="75" value="@Model.Player.ActivityScore"></meter>
            @Model.Player.ActivityScore%
          </td>
        </tr>
        <tr><th>Points</th><td><strong>@Model.Player.Skill.ToString("N0")</strong></td></tr>
        <tr><th>Rank</th><td>
            @if (Model.Player.HideRanking == 1) { <text>Hidden</text> }
            else if (Model.Player.HideRanking == 2) { <span class="text-danger">Banned</span> }
            else if (Model.Player.ActivityScore == 0) { <text>Not active</text> }
            else { <strong>#@Model.Rank.ToString("N0")</strong> }
        </td></tr>
        <tr><th>Kills per Minute</th><td>
            @(Model.Player.ConnectionTime > 0 ? Model.Player.KillsPerMinute.ToString("F2") : "-")
        </td></tr>
        <tr><th>Kills per Death</th><td>@Model.Player.KillDeathRatio (@Model.RealStats.RealKpd*)</td></tr>
        <tr><th>Headshots per Kill</th><td>@Model.Player.HeadshotPercent% (@Model.RealStats.RealHpk.ToString("F2")*)</td></tr>
        <tr><th>Weapon Accuracy</th><td>@Model.Player.Accuracy%</td></tr>
        <tr><th>Headshots</th><td>@Model.Player.Headshots.ToString("N0") (@Model.RealStats.RealHeadshots.ToString("N0")*)</td></tr>
        <tr><th>Kills</th><td>@Model.Player.Kills.ToString("N0") (@Model.RealStats.RealKills.ToString("N0")*)</td></tr>
        <tr><th>Deaths</th><td>@Model.Player.Deaths.ToString("N0") (@Model.RealStats.RealDeaths.ToString("N0")*)</td></tr>
        <tr><th>Longest Kill Streak</th><td>@Model.Player.KillStreak.ToString("N0")</td></tr>
        <tr><th>Longest Death Streak</th><td>@Model.Player.DeathStreak.ToString("N0")</td></tr>
        <tr><th>Suicides</th><td>@Model.Player.Suicides.ToString("N0")</td></tr>
        <tr><th>Teammate Kills</th><td>@Model.Player.Teamkills.ToString("N0") (@Model.RealStats.RealTeamkills.ToString("N0")*)</td></tr>
      </table>
      <p>
        <a asp-action="History" asp-route-id="@Model.Player.PlayerId">Events</a> |
        <a asp-action="Awards" asp-route-id="@Model.Player.PlayerId">Awards (@Model.Awards.Count)</a>
      </p>
      <p><small>* = from recent event records</small></p>
    </section>
  </div>

  <div class="profile-section">
    <h2>Ranks</h2>
    <div class="profile-two-col">
      <section>
        <table class="stats-table">
          <thead>
            <tr><th colspan="2">Current rank: <strong>@(Model.CurrentRank?.RankName ?? "Unranked")</strong></th></tr>
          </thead>
          <tbody>
            @if (Model.CurrentRank?.Image != null)
            {
            <tr><td colspan="2" style="text-align:center;">
              <img src="/hlstatsimg/ranks/@(Model.CurrentRank.Image).png" alt="@Model.CurrentRank.RankName" title="@Model.CurrentRank.RankName" />
            </td></tr>
            }
            <tr>
              <td style="width:60%;">
                @if (Model.NextRank != null)
                {
                  <meter min="0" max="100" low="25" high="50" optimum="75" value="@Model.RankPercent" style="width:100%;"></meter>
                }
              </td>
              <td style="width:40%;">
                @if (Model.NextRank != null)
                {
                  <text>Kills needed: <strong>@Model.RankKillsNeeded (@Model.RankPercent%)</strong></text>
                }
                else
                {
                  <strong>Maximum rank achieved!</strong>
                }
              </td>
            </tr>
          </tbody>
        </table>
      </section>
      <section>
        <table class="stats-table">
          <thead><tr><th>Rank history</th></tr></thead>
          <tbody>
            <tr><td style="text-align:center;">
              @if (Model.PastRanks.Count == 0)
              {
                <em>No previous ranks.</em>
              }
              else
              {
                @foreach (var pr in Model.PastRanks)
                {
                  <img src="/hlstatsimg/ranks/@(pr.Image)_small.png" alt="@pr.RankName" title="@pr.RankName" style="margin:2px;" />
                }
              }
            </td></tr>
          </tbody>
        </table>
      </section>
    </div>
  </div>
  @if (Model.AllRibbons.Any() || Model.GlobalAwards.Any())
  {
  <div class="profile-section">
    <h2>Awards <small style="font-size:0.7em;font-weight:normal;">(hover for name)</small></h2>
    <div style="display:flex;gap:16px;align-items:flex-start;">
      @if (Model.AllRibbons.Any())
      {
      <div style="flex:2 1 0;">
        <table class="data-table">
          <thead><tr class="data-table-head"><td>Ribbons</td></tr></thead>
          <tbody>
            <tr class="bg1">
              <td style="text-align:center;padding:8px;">
                @foreach (var r in Model.AllRibbons)
                {
                  var ribbonSrc = r.Earned && r.Image != null
                      ? $"/hlstatsimg/games/{Model.Player.Game}/ribbons/{r.Image}"
                      : $"/hlstatsimg/games/{Model.Player.Game}/ribbons/noaward.png";
                  <img src="@ribbonSrc" alt="@r.RibbonName" title="@r.RibbonName" style="border:0;margin:2px;" />
                }
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      }
      @if (Model.GlobalAwards.Any())
      {
      <div style="flex:1 1 0;">
        <table class="data-table">
          <thead><tr class="data-table-head"><td>Global Awards</td></tr></thead>
          <tbody>
            <tr class="bg1">
              <td style="text-align:center;padding:8px;">
                @foreach (var a in Model.GlobalAwards)
                {
                  var gaImg = $"/hlstatsimg/games/{Model.Player.Game}/gawards/{a.AwardType.ToLower()}_{a.Code.ToLower()}.png";
                  <img src="@gaImg" alt="@a.Name" title="@a.Name" style="border:0;margin:2px;" />
                }
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      }
    </div>
  </div>
  }

  <div class="profile-section">
    <h2>Miscellaneous Statistics</h2>
    <div class="profile-two-col">
      <section>
        <table class="data-table">
          <thead><tr class="data-table-head"><td>Player Trend</td></tr></thead>
          <tbody>
            <tr class="bg1">
              <td style="text-align:center;padding:8px;">
                @if (Model.TrendData.Count < 2)
                {
                  <em>Not enough session data to display a trend.</em>
                }
                else
                {
                  <canvas id="trendChart" width="380" height="200" style="background:#1a1a1a;border-radius:4px;"></canvas>
                }
              </td>
            </tr>
          </tbody>
        </table>
      </section>
      <section>
        <table class="data-table">
          <thead><tr class="data-table-head"><td colspan="2">Forum Signature</td></tr></thead>
          <tbody>
            <tr class="bg1">
              <td style="text-align:center;padding:12px;">
                <img src="@(Url.Action("Sig", "Players", new { id = Model.Player.PlayerId }))"
                     alt="Forum signature" title="Copy &amp; paste the URL below into your forum signature" />
                <br /><br />
                <a href="#" onclick="setSigText(1);return false;">bbCode 1 (phpBB, SMF)</a>
                &nbsp;|&nbsp;
                <a href="#" onclick="setSigText(2);return false;">bbCode 2 (IPB)</a>
                &nbsp;|&nbsp;
                <a href="#" onclick="setSigText(0);return false;">Direct Image</a>
                <br />
                <textarea id="siglink" rows="2" style="width:95%;margin-top:6px;" readonly
                          onclick="this.select()">@defaultSigText</textarea>
              </td>
            </tr>
          </tbody>
        </table>
      </section>
    </div>
  </div>
</div>

<div id="tab-aliases" class="tab-panel" style="display:none;">
  <h2>Known Aliases</h2>
  @if (Model.Aliases.Count <= 1)
  {
    <p>No aliases to display.</p>
  }
  else
  {
    <table class="stats-table sortable">
      <thead>
        <tr>
          <th>Name</th><th>Time</th><th>Last Use</th>
          <th>Kills</th><th>Deaths</th><th>K:D</th>
          <th>Headshots</th><th>HS:K</th><th>Suicides</th><th>Accuracy</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var a in Model.Aliases)
        {
          <tr>
            <td>@a.Name</td>
            <td>@FormatTime(a.ConnectionTime)</td>
            <td>@(a.LastUse.HasValue ? a.LastUse.Value.ToString("yyyy-MM-dd") : "-")</td>
            <td>@a.Kills</td>
            <td>@a.Deaths</td>
            <td>@a.KdRatio</td>
            <td>@a.Headshots</td>
            <td>@a.HsKRatio</td>
            <td>@a.Suicides</td>
            <td>@a.Accuracy%</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<div id="tab-teams" class="tab-panel" style="display:none;">
  <div class="profile-two-col">
    <section>
      <h2>Team Selection</h2>
      @if (!Model.TeamSelection.Any())
      {
        <p>No team data available.</p>
      }
      else
      {
        <table class="stats-table">
          <thead><tr><th>Team</th><th>Joined</th><th>%</th><th>Ratio</th></tr></thead>
          <tbody>
            @foreach (var t in Model.TeamSelection)
            {
              double pct = t.TotalJoins > 0 ? (double)t.JoinCount / t.TotalJoins * 100 : 0;
              <tr>
                <td>@t.TeamName</td>
                <td>@t.JoinCount times</td>
                <td>@pct.ToString("F1")%</td>
                <td><meter min="0" max="100" value="@pct.ToString("F0")" style="width:80px;"></meter></td>
              </tr>
            }
          </tbody>
        </table>
      }
    </section>
    <section>
      <h2>Role Selection</h2>
      @if (!Model.RoleSelection.Any())
      {
        <p>No role data available.</p>
      }
      else
      {
        <table class="stats-table">
          <thead><tr><th>Role</th><th>Joined</th><th>%</th><th>Kills</th><th>Deaths</th><th>K:D</th></tr></thead>
          <tbody>
            @foreach (var r in Model.RoleSelection)
            {
              <tr>
                <td>
                  @if (!string.IsNullOrEmpty(r.RoleImage))
                  {
                    <img src="/hlstatsimg/games/@Model.Player.Game/roles/@r.RoleImage" alt="@r.RoleCode" style="height:16px;" />
                  }
                  @r.RoleCode
                </td>
                <td>@r.JoinCount times</td>
                <td>@(r.TotalJoins > 0 ? $"{(double)r.JoinCount / r.TotalJoins * 100:F1}%" : "-")</td>
                <td>@r.Kills</td>
                <td>@r.Deaths</td>
                <td>@(r.Deaths == 0 ? r.Kills.ToString() : $"{(double)r.Kills / r.Deaths:F2}")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </section>
  </div>

  @if (Model.PlayerActions.Any())
  {
  <div class="profile-section">
    <h2>Player Actions *</h2>
    <table class="stats-table">
      <thead><tr><th>Action</th><th style="text-align:right;">Earned</th><th style="text-align:right;">Accumulated Points</th></tr></thead>
      <tbody>
        @foreach (var a in Model.PlayerActions)
        {
          <tr>
            <td>@a.Description</td>
            <td style="text-align:right;">@a.Count.ToString("N0") times</td>
            <td style="text-align:right;">@a.AccumulatedPoints.ToString("N0")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
  }

  @if (Model.PlayerActionVictims.Any())
  {
  <div class="profile-section">
    <h2>Victims of Player-Player Actions *</h2>
    <table class="stats-table">
      <thead><tr><th>Action</th><th style="text-align:right;">Earned Against</th><th style="text-align:right;">Accumulated Points</th></tr></thead>
      <tbody>
        @foreach (var a in Model.PlayerActionVictims)
        {
          <tr>
            <td>@a.Description</td>
            <td style="text-align:right;">@a.Count.ToString("N0") times</td>
            <td style="text-align:right;">@a.AccumulatedPoints.ToString("N0")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
  }
</div>

<div id="tab-weapons" class="tab-panel" style="display:none;">
  <h2>Weapon Usage</h2>
  @if (!Model.WeaponStats.Any())
  {
    <p>No weapon data available.</p>
  }
  else
  {
    long totalKills = Model.WeaponStats.Sum(w => w.Kills);
    long totalHeadshots = Model.WeaponStats.Sum(w => w.Headshots);
    <table class="stats-table">
      <thead>
        <tr>
          <th>Weapon</th><th>Modifier</th>
          <th>Kills</th><th>%</th>
          <th>Headshots</th><th>%</th><th>HS:K</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var w in Model.WeaponStats)
        {
          <tr>
            <td>@w.WeaponName</td>
            <td>@w.Modifier.ToString("F2")</td>
            <td>@w.Kills</td>
            <td>@(totalKills > 0 ? $"{(double)w.Kills / totalKills * 100:F1}%" : "-")</td>
            <td>@w.Headshots</td>
            <td>@(totalHeadshots > 0 ? $"{(double)w.Headshots / totalHeadshots * 100:F1}%" : "-")</td>
            <td>@(w.Kills > 0 ? $"{(double)w.Headshots / w.Kills:F2}" : "-")</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<div id="tab-maps" class="tab-panel" style="display:none;">
  <div class="profile-two-col">
    <section>
      <h2>Map Performance</h2>
      @if (!Model.MapPerformance.Any())
      {
        <p>No map data available.</p>
      }
      else
      {
        long mpTotalKills = Model.MapPerformance.Sum(m => m.Kills);
        long mpTotalDeaths = Model.MapPerformance.Sum(m => m.Deaths);
        long mpTotalHS = Model.MapPerformance.Sum(m => m.Headshots);
        <table class="stats-table">
          <thead>
            <tr><th>Map</th><th>Kills</th><th>%</th><th>Deaths</th><th>%</th><th>K:D</th><th>HS</th><th>HS:K</th></tr>
          </thead>
          <tbody>
            @foreach (var m in Model.MapPerformance)
            {
              <tr>
                <td>@m.Map</td>
                <td>@m.Kills</td>
                <td>@(mpTotalKills > 0 ? $"{(double)m.Kills / mpTotalKills * 100:F1}%" : "-")</td>
                <td>@m.Deaths</td>
                <td>@(mpTotalDeaths > 0 ? $"{(double)m.Deaths / mpTotalDeaths * 100:F1}%" : "-")</td>
                <td>@(m.Deaths == 0 ? m.Kills.ToString() : $"{(double)m.Kills / m.Deaths:F2}")</td>
                <td>@m.Headshots</td>
                <td>@(m.Kills == 0 ? "-" : $"{(double)m.Headshots / m.Kills:F2}")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </section>
    <section>
      <h2>Server Activity</h2>
      @if (!Model.ServerPerformance.Any())
      {
        <p>No server data available.</p>
      }
      else
      {
        long spTotalKills = Model.ServerPerformance.Sum(s => s.Kills);
        <table class="stats-table">
          <thead>
            <tr><th>Server</th><th>Kills</th><th>%</th><th>Deaths</th><th>K:D</th><th>HS</th><th>HS:K</th></tr>
          </thead>
          <tbody>
            @foreach (var s in Model.ServerPerformance)
            {
              <tr>
                <td>@s.ServerName</td>
                <td>@s.Kills</td>
                <td>@(spTotalKills > 0 ? $"{(double)s.Kills / spTotalKills * 100:F1}%" : "-")</td>
                <td>@s.Deaths</td>
                <td>@(s.Deaths == 0 ? s.Kills.ToString() : $"{(double)s.Kills / s.Deaths:F2}")</td>
                <td>@s.Headshots</td>
                <td>@(s.Kills == 0 ? "-" : $"{(double)s.Headshots / s.Kills:F2}")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </section>
  </div>
</div>

<div id="tab-kills" class="tab-panel" style="display:none;">
  <h2>Kill Statistics</h2>
  @if (!Model.KillStats.Any())
  {
    <p>No kill stat data available (minimum 5 kills against a single player).</p>
  }
  else
  {
    long ksTotalKills = Model.KillStats.Sum(k => k.Kills);
    long ksTotalDeaths = Model.KillStats.Sum(k => k.Deaths);
    long ksTotalHS = Model.KillStats.Sum(k => k.Headshots);
    <table class="stats-table">
      <thead>
        <tr>
          <th>Victim</th>
          <th>Kills</th><th>%</th>
          <th>Deaths</th><th>%</th>
          <th>K:D</th>
          <th>Headshots</th><th>%</th><th>HS:K</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var k in Model.KillStats)
        {
          <tr>
            <td><a asp-action="Profile" asp-route-id="@k.VictimId">@k.VictimName</a></td>
            <td>@k.Kills</td>
            <td>@(ksTotalKills > 0 ? $"{(double)k.Kills / ksTotalKills * 100:F1}%" : "-")</td>
            <td>@k.Deaths</td>
            <td>@(ksTotalDeaths > 0 ? $"{(double)k.Deaths / ksTotalDeaths * 100:F1}%" : "-")</td>
            <td>@(k.Deaths == 0 ? k.Kills.ToString() : $"{(double)k.Kills / k.Deaths:F2}")</td>
            <td>@k.Headshots</td>
            <td>@(ksTotalHS > 0 ? $"{(double)k.Headshots / ksTotalHS * 100:F1}%" : "-")</td>
            <td>@(k.Kills == 0 ? "-" : $"{(double)k.Headshots / k.Kills:F2}")</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
document.querySelectorAll('.tab-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
        e.preventDefault();
        document.querySelectorAll('.tab-link').forEach(function(l) { l.classList.remove('active'); });
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.style.display = 'none'; });
        this.classList.add('active');
        document.querySelector(this.getAttribute('href')).style.display = 'block';
    });
});

@if (Model.TrendData.Count >= 2)
{
    var labels   = Model.TrendData.Select(t => t.EventTime.ToString("MMM d")).ToArray();
    var skills   = Model.TrendData.Select(t => (double)t.Skill / 1000.0).ToArray();
    var sessions = Model.TrendData.Select(t => (double)t.SkillChange).ToArray();

    <text>
(function() {
    var ctx = document.getElementById('trendChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels)),
            datasets: [
                {
                    label: 'Skill (K)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(skills)),
                    borderColor: 'rgb(255, 255, 0)',
                    backgroundColor: 'rgba(255, 255, 0, 0.1)',
                    tension: 0.4,
                    yAxisID: 'ySkill'
                },
                {
                    label: 'Session',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessions)),
                    borderColor: 'rgb(255, 80, 80)',
                    backgroundColor: 'rgba(255, 80, 80, 0.1)',
                    tension: 0.4,
                    yAxisID: 'ySession'
                }
            ]
        },
        options: {
            responsive: false,
            plugins: { legend: { labels: { color: '#ddd' } } },
            scales: {
                ySkill: {
                    type: 'linear', position: 'right',
                    ticks: { color: '#ddd' },
                    grid: { color: '#444' },
                    title: { display: true, text: 'Skill', color: '#ddd' }
                },
                ySession: {
                    type: 'linear', position: 'left',
                    ticks: { color: '#ddd' },
                    grid: { color: '#333' },
                    title: { display: true, text: 'Session', color: '#ddd' }
                },
                x: {
                    ticks: { color: '#ddd' },
                    grid: { color: '#333' },
                    title: { display: true, text: 'Date', color: '#ddd' }
                }
            }
        }
    });
})();
    </text>
}

// Forum signature text switcher
var sigImgUrl  = '@sigAbsUrl';
var profileUrl = '@profileAbsUrl';
function setSigText(mode) {
    var ta = document.getElementById('siglink');
    if (!ta) return;
    if (mode === 0) { ta.value = sigImgUrl; }
    else if (mode === 1) { ta.value = '[url=' + profileUrl + '][img]' + sigImgUrl + '[/img][/url]'; }
    else if (mode === 2) { ta.value = '[url="' + profileUrl + '"][img]' + sigImgUrl + '[/img][/url]'; }
    ta.select();
}
</script>
}
