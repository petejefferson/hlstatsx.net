@model PlayerHistoryViewModel
@{
    ViewData["Title"] = $"{Model.Player.LastName} - History";
}

<h1>Skill History &mdash; @Model.Player.LastName</h1>

<div class="history-filters">
    <a asp-action="History" asp-route-id="@Model.Player.PlayerId" asp-route-days="7" class="@(Model.Days == 7 ? "active" : "")">7 days</a>
    <a asp-action="History" asp-route-id="@Model.Player.PlayerId" asp-route-days="30" class="@(Model.Days == 30 ? "active" : "")">30 days</a>
    <a asp-action="History" asp-route-id="@Model.Player.PlayerId" asp-route-days="90" class="@(Model.Days == 90 ? "active" : "")">90 days</a>
</div>

@if (Model.History.Any())
{
    <table class="stats-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Skill</th>
                <th>Change</th>
                <th>Kills</th>
                <th>Deaths</th>
                <th>Headshots</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var h in Model.History.OrderByDescending(x => x.EventTime))
            {
                <tr>
                    <td>@h.EventTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@h.Skill</td>
                    <td class="@(h.SkillChange >= 0 ? "positive" : "negative")">
                        @(h.SkillChange >= 0 ? "+" : "")@h.SkillChange
                    </td>
                    <td>@h.Kills</td>
                    <td>@h.Deaths</td>
                    <td>@h.Headshots</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No history available for the last @Model.Days days.</p>
}

<p><a asp-action="Profile" asp-route-id="@Model.Player.PlayerId">&larr; Back to profile</a></p>
