@model HomeViewModel
@{
    ViewData["Title"] = "Home";

    // Per-server load chart (type 0 equivalent)
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(
        Model.ServerLoad.Select(x => x.DateTime.ToString("HH:mm")));
    var chartData = System.Text.Json.JsonSerializer.Serialize(
        Model.ServerLoad.Select(x => x.ActPlayers));
    var chartMaps = System.Text.Json.JsonSerializer.Serialize(
        Model.ServerLoad.Select(x => x.Map ?? ""));
    var chartMax = Model.ServerLoad.Any() ? Model.ServerLoad.Max(x => x.MaxPlayers) : 32;

    // Aggregate trend chart (type 1 equivalent)
    var trendLabels = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => DateTimeOffset.FromUnixTimeSeconds(x.Timestamp).LocalDateTime.ToString("HH:mm")));
    var trendActSlots = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => x.ActSlots));
    var trendMaxSlots = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => x.MaxSlots));
    var trendKills = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => x.Kills));
    var trendHeadshots = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => x.Headshots));
    var trendPlayers = System.Text.Json.JsonSerializer.Serialize(
        Model.TrendSeries.Select(x => x.Players));
    var trendMaxY = Model.TrendSeries.Any() ? Model.TrendSeries.Max(x => x.MaxSlots) : 32;
}

<h2>Participating Servers</h2>

<table class="data-table" style="margin-bottom:0;">
    <tr class="data-table-head">
        <td>
            Tracking <strong>@Model.TotalPlayers.ToString("N0")</strong> players
            @if (Model.NewPlayersLast24h >= 0)
            {
                <text>(<strong>+@Model.NewPlayersLast24h.ToString("N0")</strong> new players last 24h) </text>
            }
            with <strong>@Model.Stats.TotalKills.ToString("N0")</strong> kills
            @if (Model.Stats.NewKillsLast24h >= 0)
            {
                <text>(<strong>+@Model.Stats.NewKillsLast24h.ToString("N0")</strong> last 24h) </text>
            }
            and <strong>@Model.Stats.TotalHeadshots.ToString("N0")</strong> headshots
            (<strong>@Model.Stats.HeadshotPercent.ToString("F2")%</strong>)
            on <strong>@Model.Stats.TotalServers.ToString("N0")</strong> server@(Model.Stats.TotalServers == 1 ? "" : "s")
        </td>
    </tr>
</table>

@if (Model.TrendSeries.Any())
{
    <section class="chart-section" style="margin-bottom:1rem;">
        <p style="text-align:right;font-size:0.8rem;color:var(--muted);margin-bottom:0.25rem;">
            New Players Last 24h: <strong>@(Model.NewPlayersLast24h >= 0 ? "+" + Model.NewPlayersLast24h.ToString("N0") : "N/A")</strong>
            &nbsp; Last 1h: <strong>@(Model.NewPlayersLast1h >= 0 ? "+" + Model.NewPlayersLast1h.ToString("N0") : "N/A")</strong>
        </p>
        <canvas id="trendChart" height="80"></canvas>
    </section>
}

@if (Model.Servers.Any())
{
    <table class="data-table" style="margin-bottom:0;">
        <thead>
            <tr class="data-table-head">
                <th style="width:37%;text-align:left;">Server</th>
                <th style="width:23%;text-align:left;">Address</th>
                <th style="width:6%;text-align:center;">Map</th>
                <th style="width:6%;text-align:center;">Played</th>
                <th style="width:10%;text-align:center;">Players</th>
                <th style="width:6%;text-align:center;">Kills</th>
                <th style="width:6%;text-align:center;">Headshots</th>
                <th style="width:6%;text-align:center;">Hpk</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sv in Model.Servers)
            {
                long elapsed = sv.MapStarted > 0 ? DateTimeOffset.UtcNow.ToUnixTimeSeconds() - sv.MapStarted : 0;
                if (elapsed < 0) elapsed = 0;
                string mapTime = $"{elapsed / 3600:D2}:{elapsed % 3600 / 60:D2}:{elapsed % 60:D2}";
                double hpk = sv.Kills > 0 ? (double)sv.Headshots / sv.Kills : 0.0;
                <tr class="bg1">
                    <td><a asp-controller="Servers" asp-action="Detail" asp-route-id="@sv.ServerId">@sv.Name</a></td>
                    <td>
                        @sv.DisplayAddress
                        <a href="steam://connect/@sv.DisplayAddress">(Join)</a>
                    </td>
                    <td style="text-align:center;">@sv.ActMap</td>
                    <td style="text-align:center;">@mapTime</td>
                    <td style="text-align:center;">@sv.ActPlayers / @sv.MaxPlayers</td>
                    <td style="text-align:center;">@sv.Kills.ToString("N0")</td>
                    <td style="text-align:center;">@sv.Headshots.ToString("N0")</td>
                    <td style="text-align:center;">@hpk.ToString("F4")</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.ServerLoad.Any())
{
    <section class="chart-section">
        <p style="text-align:right;font-size:0.8rem;color:var(--muted);margin-bottom:0.25rem;">
            Average Players Last 24h: <strong>@Model.AvgPlayersLast24h.ToString("F1")</strong>
            &nbsp; Last 1h: <strong>@Model.AvgPlayersLast1h.ToString("F1")</strong>
        </p>
        <canvas id="activityChart" height="80"></canvas>
    </section>
}

@if (Model.Livestats.Any())
{
    <section>
        <table class="livestats-table">
            <thead>
                <tr class="livestats-head">
                    <th style="width:3%;">#</th>
                    <th style="width:35%;text-align:left;">Player</th>
                    <th colspan="3" style="width:8%;">Kills</th>
                    <th style="width:5%;">Hs</th>
                    <th style="width:7%;">HS:K</th>
                    <th style="width:6%;">Acc</th>
                    <th style="width:10%;">Time</th>
                    <th style="width:6%;">+/-</th>
                    <th style="width:7%;">Skill</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var teamGroup in Model.PlayersByTeam)
            {
                var team = Model.GetTeam(teamGroup.Key);
                bool isUnassigned = team is null;
                var bgColor  = team?.PlayerlistBgcolor ?? "#D5D5D5";
                var txtColor = team?.PlayerlistColor   ?? "#050505";
                var teamName = team?.Name is { Length: > 0 } n ? n : teamGroup.Key;
                var rowStyle  = $"background:{bgColor};color:{txtColor};";
                var footStyle = $"background:{bgColor};color:{txtColor};border-top:1px {txtColor} solid;";

                int j = 1;
                @foreach (var ls in teamGroup)
                {
                    <tr style="@rowStyle">
                        <td>@(isUnassigned ? "" : j.ToString())</td>
                        <td style="text-align:left;">
                            @{
                                var flagFile = string.IsNullOrEmpty(ls.CliFlag) ? "0" : ls.CliFlag.ToLowerInvariant();
                                var flagAlt  = string.IsNullOrEmpty(ls.CliCountry) ? "" : ls.CliCountry;
                            }
                            <img src="/hlstatsimg/flags/@(flagFile).gif" alt="@flagAlt" title="@flagAlt" />&nbsp;
                            @if (ls.PlayerId > 0)
                            {
                                <a style="color:@txtColor"
                                   asp-controller="Players" asp-action="Profile" asp-route-id="@ls.PlayerId">@ls.Name</a>
                            }
                            else { @ls.Name }
                        </td>
                        <td style="text-align:right;">@ls.Kills</td>
                        <td>:</td>
                        <td style="text-align:left;">@ls.Deaths</td>
                        <td>@ls.Headshots</td>
                        <td>@ls.HeadshotPercent.ToString("F2")</td>
                        <td>@ls.Accuracy.ToString("F0")%</td>
                        <td>@ls.ConnectedFormatted</td>
                        <td>@ls.SkillChange</td>
                        <td>@ls.Skill.ToString("N0")</td>
                    </tr>
                    j++;
                }

                @if (!isUnassigned)
                {
                    var teamKills  = teamGroup.Sum(p => p.Kills);
                    var teamDeaths = teamGroup.Sum(p => p.Deaths);
                    var teamHs     = teamGroup.Sum(p => p.Headshots);
                    var teamShots  = teamGroup.Sum(p => p.Shots);
                    var teamHits   = teamGroup.Sum(p => p.Hits);
                    var teamHsk    = teamKills > 0 ? ((double)teamHs / teamKills).ToString("F2") : "0.00";
                    var teamAcc    = teamShots > 0 ? ((double)teamHits / teamShots * 100).ToString("F0") + "%" : "0%";
                    var teamSkill  = teamGroup.Any() ? ((int)teamGroup.Average(p => p.Skill)).ToString("N0") : "-";
                    <tr style="@footStyle">
                        <td>&nbsp;</td>
                        <td style="text-align:left;"><strong>@teamName</strong></td>
                        <td style="text-align:right;">@teamKills</td>
                        <td>:</td>
                        <td style="text-align:left;">@teamDeaths</td>
                        <td>@teamHs</td>
                        <td>@teamHsk</td>
                        <td>@teamAcc</td>
                        <td>&nbsp;</td>
                        <td>-</td>
                        <td>@teamSkill</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </section>
}
else
{
    <section>
        <p>No players online right now.</p>
    </section>
}

@if (Model.DailyAwards.Any())
{
    <section>
        <h2>Daily Awards &mdash; @DateTime.Now.ToString("dddd, MMMM d")</h2>
        <table class="data-table">
            <thead>
                <tr class="data-table-head">
                    <th style="text-align:left;">Award</th>
                    <th style="text-align:left;">Winner</th>
                </tr>
            </thead>
            <tbody>
                @{ int awardRow = 0; }
                @foreach (var a in Model.DailyAwards)
                {
                    <tr class="@(awardRow % 2 == 0 ? "bg1" : "bg2")">
                        <td><a asp-controller="Awards" asp-action="DailyAwardDetail" asp-route-id="@a.AwardId" asp-route-game="@Model.Game">@a.Name</a></td>
                        <td>
                            @if (a.DailyWinner is not null)
                            {
                                @if (!string.IsNullOrEmpty(a.DailyWinner.Flag))
                                {
                                    <img src="/hlstatsimg/flags/@(a.DailyWinner.Flag.ToLowerInvariant()).gif"
                                         alt="@a.DailyWinner.Country" title="@a.DailyWinner.Country" />
                                }
                                <a asp-controller="Players" asp-action="Profile"
                                   asp-route-id="@a.DailyWinner.PlayerId"><strong>@a.DailyWinner.LastName</strong></a>
                                @($" ({a.DailyWinnerCount} {a.Verb})")
                            }
                            else
                            {
                                <text>&nbsp;&nbsp; <em>No Award Winner</em></text>
                            }
                        </td>
                    </tr>
                    awardRow++;
                }
            </tbody>
        </table>
    </section>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

    @if (Model.TrendSeries.Any())
    {
        <script>
        (function () {
            const labels      = @Html.Raw(trendLabels);
            const actSlots    = @Html.Raw(trendActSlots);
            const maxSlots    = @Html.Raw(trendMaxSlots);
            const kills       = @Html.Raw(trendKills);
            const headshots   = @Html.Raw(trendHeadshots);
            const players     = @Html.Raw(trendPlayers);

            new Chart(document.getElementById('trendChart'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Active Players',
                            data: actSlots,
                            borderColor: '#0000FF',
                            backgroundColor: 'rgba(0,0,255,0.08)',
                            borderWidth: 1.5,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.2,
                            yAxisID: 'ySlots'
                        },
                        {
                            label: 'Max Slots',
                            data: maxSlots,
                            borderColor: '#696969',
                            borderWidth: 1,
                            borderDash: [4, 3],
                            pointRadius: 0,
                            fill: false,
                            tension: 0,
                            yAxisID: 'ySlots'
                        },
                        {
                            label: 'Kills',
                            data: kills,
                            borderColor: '#FFA500',
                            borderWidth: 1,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.2,
                            yAxisID: 'yCounts'
                        },
                        {
                            label: 'Headshots',
                            data: headshots,
                            borderColor: '#99AAAA',
                            borderWidth: 1,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.2,
                            yAxisID: 'yCounts'
                        },
                        {
                            label: 'Registered Players',
                            data: players,
                            borderColor: '#CC0000',
                            borderWidth: 1,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.2,
                            yAxisID: 'yCounts'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: true, position: 'top', labels: { boxWidth: 12, font: { size: 11 } } }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#333', maxTicksLimit: 12 },
                            grid: { color: '#ddd' },
                            title: { display: true, text: 'Time', color: '#555', font: { size: 11 } }
                        },
                        ySlots: {
                            type: 'linear',
                            position: 'left',
                            beginAtZero: true,
                            ticks: { color: '#333', stepSize: 4 },
                            grid: { color: '#ddd' },
                            title: { display: true, text: 'Players', color: '#555', font: { size: 11 } }
                        },
                        yCounts: {
                            type: 'linear',
                            position: 'right',
                            beginAtZero: false,
                            ticks: { color: '#999' },
                            grid: { drawOnChartArea: false },
                            title: { display: true, text: 'Cumulative', color: '#999', font: { size: 11 } }
                        }
                    }
                }
            });
        })();
        </script>
    }

    @if (Model.ServerLoad.Any())
    {
        <script>
        (function () {
            const labels = @Html.Raw(chartLabels);
            const data   = @Html.Raw(chartData);
            const maps   = @Html.Raw(chartMaps);
            const maxY   = @chartMax;

            const mapSegments = [];
            let lastMap = null;
            for (let i = 0; i < maps.length; i++) {
                const m = maps[i] && maps[i] !== '+' ? maps[i] : null;
                if (m && m !== lastMap) {
                    mapSegments.push({ startIndex: i, map: m });
                    lastMap = m;
                }
            }

            const mapOverlayPlugin = {
                id: 'mapOverlay',
                afterDraw(chart) {
                    if (!mapSegments.length) return;
                    const { ctx, chartArea: { top, bottom, left, right }, scales: { x } } = chart;
                    ctx.save();
                    for (let s = 0; s < mapSegments.length; s++) {
                        const seg = mapSegments[s];
                        const nextStart = s + 1 < mapSegments.length ? mapSegments[s + 1].startIndex : maps.length - 1;
                        const midIndex = Math.round((seg.startIndex + nextStart) / 2);
                        const xStart = seg.startIndex > 0 ? x.getPixelForValue(seg.startIndex) : left;
                        const xMid = x.getPixelForValue(midIndex);

                        if (seg.startIndex > 0) {
                            ctx.setLineDash([4, 3]);
                            ctx.strokeStyle = 'rgba(80,80,80,0.45)';
                            ctx.lineWidth = 1;
                            ctx.beginPath();
                            ctx.moveTo(xStart, top);
                            ctx.lineTo(xStart, bottom);
                            ctx.stroke();
                            ctx.setLineDash([]);
                        }

                        ctx.save();
                        ctx.font = '11px sans-serif';
                        ctx.fillStyle = 'rgba(50,50,50,0.65)';
                        ctx.textAlign = 'right';
                        ctx.textBaseline = 'middle';
                        ctx.translate(xMid, top);
                        ctx.rotate(-Math.PI / 2);
                        ctx.fillText(seg.map, -6, 0);
                        ctx.restore();
                    }
                    ctx.restore();
                }
            };

            new Chart(document.getElementById('activityChart'), {
                type: 'line',
                plugins: [mapOverlayPlugin],
                data: {
                    labels,
                    datasets: [{
                        label: 'Players',
                        data,
                        backgroundColor: 'rgba(171,204,214,0.4)',
                        borderColor: '#5b9aad',
                        borderWidth: 2,
                        pointRadius: 0,
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(ctx) {
                                    const map = maps[ctx.dataIndex];
                                    const mapLabel = map && map !== '+' ? ` — ${map}` : '';
                                    return `${ctx.parsed.y} players${mapLabel}`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#333', maxTicksLimit: 12 },
                            grid: { color: '#ddd' },
                            title: { display: true, text: 'Time', color: '#555', font: { size: 11 } }
                        },
                        y: {
                            ticks: { color: '#333', stepSize: 4 },
                            grid: { color: '#ddd' },
                            beginAtZero: true,
                            max: maxY,
                            title: { display: true, text: 'Player Count', color: '#555', font: { size: 11 } }
                        }
                    }
                }
            });
        })();
        </script>
    }
}
