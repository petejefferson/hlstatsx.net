@model ServerDetailViewModel
@{
    ViewData["Title"] = Model.Server.Name;

    var s = Model.Server;
    long elapsed = s.MapStarted > 0 ? DateTimeOffset.UtcNow.ToUnixTimeSeconds() - s.MapStarted : 0;
    if (elapsed < 0) elapsed = 0;
    string mapTime = $"{elapsed / 3600:D2}:{elapsed % 3600 / 60:D2}:{elapsed % 60:D2}";
    double hpk = s.Kills > 0 ? (double)s.Headshots / s.Kills : 0.0;
}

<h1>Server Live View</h1>

<table class="data-table">
    <thead>
        <tr class="data-table-head">
            <th style="width:37%;text-align:left;">Server</th>
            <th style="width:23%;text-align:left;">Address</th>
            <th style="width:6%;text-align:center;">Map</th>
            <th style="width:6%;text-align:center;">Played</th>
            <th style="width:10%;text-align:center;">Players</th>
            <th style="width:6%;text-align:center;">Kills</th>
            <th style="width:6%;text-align:center;">Headshots</th>
            <th style="width:6%;text-align:center;">Hpk</th>
        </tr>
    </thead>
    <tbody>
        <tr class="bg1">
            <td><strong>@s.Name</strong></td>
            <td>
                @s.DisplayAddress
                <a href="steam://connect/@s.DisplayAddress">(Join)</a>
            </td>
            <td style="text-align:center;">@s.ActMap</td>
            <td style="text-align:center;">@mapTime</td>
            <td style="text-align:center;">@s.ActPlayers / @s.MaxPlayers</td>
            <td style="text-align:center;">@s.Kills.ToString("N0")</td>
            <td style="text-align:center;">@s.Headshots.ToString("N0")</td>
            <td style="text-align:center;">@hpk.ToString("F4")</td>
        </tr>
    </tbody>
</table>

<section>
    <h2>Live Players (@Model.Livestats.Count)</h2>
    @if (Model.Livestats.Any())
    {
        <table class="stats-table">
            <thead>
                <tr>
                    <th>Player</th>
                    <th>Team</th>
                    <th>Kills</th>
                    <th>Deaths</th>
                    <th>Skill</th>
                    <th>Ping</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ls in Model.Livestats.OrderByDescending(l => l.Skill))
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(ls.CliFlag))
                            {
                                <img src="/hlstatsimg/flags/@(ls.CliFlag.ToLowerInvariant()).gif" alt="@ls.CliCountry" title="@ls.CliCountry" />
                            }
                            @if (ls.PlayerId > 0)
                            {
                                <a asp-controller="Players" asp-action="Profile" asp-route-id="@ls.PlayerId">@ls.Name</a>
                            }
                            else
                            {
                                @ls.Name
                            }
                            @if (ls.IsDead) { <small>(dead)</small> }
                        </td>
                        <td>@ls.Team</td>
                        <td>@ls.Kills</td>
                        <td>@ls.Deaths</td>
                        <td>@ls.Skill</td>
                        <td>@ls.Ping</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No players currently online.</p>
    }
</section>
