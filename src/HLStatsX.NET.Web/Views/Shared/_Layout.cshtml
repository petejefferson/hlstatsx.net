<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(Configuration["HLStatsX:SiteName"] ?? "HLStatsX.NET")</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">HLStatsX.NET</a>
            <ul class="nav-links">
                <li><a asp-controller="Servers" asp-action="Index">Servers</a></li>
                <li><a asp-controller="Players" asp-action="Index">Players</a></li>
                <li><a asp-controller="Clans" asp-action="Index">Clans</a></li>
                <li><a asp-controller="Countries" asp-action="Index">Countries</a></li>
                <li><a asp-controller="Awards" asp-action="Index">Awards</a></li>
                <li><a asp-controller="Awards" asp-action="Ranks">Ranks</a></li>
                <li><a asp-controller="Awards" asp-action="Ribbons">Ribbons</a></li>
                <li><a asp-controller="Actions" asp-action="Index">Actions</a></li>
                <li><a asp-controller="Weapons" asp-action="Index">Weapons</a></li>
                <li><a asp-controller="Maps" asp-action="Index">Maps</a></li>
                <li><a asp-controller="Roles" asp-action="Index">Roles</a></li>
                <li><a asp-controller="Search" asp-action="Index">Search</a></li>
            </ul>
        </nav>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer>
        <p>Powered by HLStatsX.NET &mdash; C# ASP.NET Core Edition</p>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
