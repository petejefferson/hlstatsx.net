@model HLStatsX.NET.Core.Models.SearchResults?
@{
    ViewData["Title"] = "Search";
    var query = Model?.Query ?? "";
}

<h1>Search</h1>

<form method="get" asp-action="Index">
    <input type="text" name="q" value="@query" placeholder="Search players and clans..." />
    <button type="submit">Search</button>
</form>

@if (Model is not null)
{
    <section>
        <h2>Players (@Model.TotalPlayers found)</h2>
        @if (Model.Players.Any())
        {
            <table class="stats-table">
                <thead><tr><th>Player</th><th>Skill</th><th>Kills</th></tr></thead>
                <tbody>
                    @foreach (var p in Model.Players)
                    {
                        <tr>
                            <td><a asp-controller="Players" asp-action="Profile" asp-route-id="@p.PlayerId">@p.LastName</a></td>
                            <td>@p.Skill</td>
                            <td>@p.Kills</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No players found.</p>
        }
    </section>

    <section>
        <h2>Clans (@Model.TotalClans found)</h2>
        @if (Model.Clans.Any())
        {
            <table class="stats-table">
                <thead><tr><th>Clan</th><th>Tag</th></tr></thead>
                <tbody>
                    @foreach (var c in Model.Clans)
                    {
                        <tr>
                            <td><a asp-controller="Clans" asp-action="Profile" asp-route-id="@c.ClanId">@c.Name</a></td>
                            <td>@c.Tag</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No clans found.</p>
        }
    </section>
}
