<h1>@Model.Clan.Tag &mdash; @Model.Clan.Name</h1>

<div class="profile-tabs" id="profileTabs">
    <a href="#tab-general"  class="tab-link active">General</a>
    <a href="#tab-actions"  class="tab-link">Teams &amp; Actions</a>
    <a href="#tab-weapons"  class="tab-link">Weapons</a>
    <a href="#tab-maps"     class="tab-link">Maps</a>
</div>

@* ══════════════════════════════════════════════════════ GENERAL TAB *@
<div id="tab-general" class="tab-panel active">

  <div class="profile-two-col">
    <section class="profile-card">
      <table class="data-table">
        <tr class="data-table-head"><th colspan="2">Statistics Summary</th></tr>
        <tr class="bg1">
          <td>Clan:</td>
          <td><strong>@Model.Clan.Name</strong></td>
        </tr>
        <tr class="bg2">
          <td>Home Page:</td>
          <td>
            @if (!string.IsNullOrWhiteSpace(Model.Clan.Homepage))
            {
              <a href="@Model.Clan.Homepage" target="_blank" rel="noopener">@Model.Clan.Homepage</a>
            }
            else { <text>(Not specified.)</text> }
          </td>
        </tr>
        <tr class="bg1">
          <td>Activity:</td>
          <td>
            <activity-meter value="@Model.Summary.AvgActivity" style="width:120px;" />
            @Model.Summary.AvgActivity.ToString("F2")%
          </td>
        </tr>
        <tr class="bg2">
          <td>Members:</td>
          <td>@Model.Summary.ActiveMemberCount active (@Model.Summary.TotalMemberCount total)</td>
        </tr>
        <tr class="bg1">
          <td>Avg. Member Points:</td>
          <td><strong>@Model.Summary.AvgSkill.ToString("N0")</strong></td>
        </tr>
        <tr class="bg2">
          <td>Total Kills:</td>
          <td>@Model.Summary.TotalKills.ToString("N0")</td>
        </tr>
        <tr class="bg1">
          <td>Total Deaths:</td>
          <td>@Model.Summary.TotalDeaths.ToString("N0")</td>
        </tr>
        <tr class="bg2">
          <td>Avg. Kills:</td>
          <td>@(Model.Summary.ActiveMemberCount == 0 ? "-" : (Model.Summary.TotalKills / Model.Summary.ActiveMemberCount).ToString("N0"))</td>
        </tr>
        <tr class="bg1">
          <td>Kills per Death:</td>
          <td>
            @if (Model.Summary.TotalDeaths != 0)
            {
              <strong>@((Model.Summary.TotalKills / (double)Model.Summary.TotalDeaths).ToString("F2"))</strong>
            }
            else { <text>-</text> }
          </td>
        </tr>
        <tr class="bg2">
          <td>Kills per Minute:</td>
          <td>
            @if (Model.Summary.TotalConnectionTime > 0)
            {
              @((Model.Summary.TotalKills / (Model.Summary.TotalConnectionTime / 60.0)).ToString("F2"))
            }
            else { <text>-</text> }
          </td>
        </tr>
        <tr class="bg1">
          <td>Total Connection Time:</td>
          <td>@RazorHelpers.FormatTimeFull(Model.Summary.TotalConnectionTime)</td>
        </tr>
        <tr class="bg2">
          <td>Avg. Connection Time:</td>
          <td>
            @if (Model.Summary.ActiveMemberCount > 0 && Model.Summary.TotalConnectionTime > 0)
            {
              @RazorHelpers.FormatTimeFull(Model.Summary.TotalConnectionTime / Model.Summary.ActiveMemberCount)
            }
            else { <text>-</text> }
          </td>
        </tr>
        <tr class="bg1">
          <td>Favourite Server:*</td>
          <td>
            @if (Model.FavoriteServer is not null)
            {
              <a asp-controller="Servers" asp-action="Detail" asp-route-id="@Model.FavoriteServer.ServerId">@Model.FavoriteServer.ServerName</a>
            }
            else { <text>-</text> }
          </td>
        </tr>
        <tr class="bg2">
          <td>Favourite Map:*</td>
          <td>
            @if (Model.FavoriteMap is not null)
            {
              <a asp-controller="Maps" asp-action="Detail" asp-route-map="@Model.FavoriteMap" asp-route-game="@(Model.Game)">@Model.FavoriteMap</a>
            }
            else { <text>-</text> }
          </td>
        </tr>
        <tr class="bg1">
          <td>Favourite Weapon:*</td>
          <td>
            @if (Model.FavoriteWeapon is not null)
            {
              <a asp-controller="Weapons" asp-action="Detail" asp-route-code="@(Model.FavoriteWeapon.WeaponCode)" asp-route-game="@(Model.Game)">
                <img src="/hlstatsimg/games/@(Model.Game)/weapons/@(Model.FavoriteWeapon.WeaponCode).gif"
                     alt="@Model.FavoriteWeapon.WeaponName" title="@Model.FavoriteWeapon.WeaponName"
                     style="vertical-align:middle;max-height:24px;"
                     onerror="this.style.display='none'" />
                @Model.FavoriteWeapon.WeaponName
              </a>
            }
            else { <text>-</text> }
          </td>
        </tr>
      </table>
    </section>

    @* ══════════════════════════════════════════════════════ PLAYER LOCATIONS *@
    <section class="profile-card">
      <table class="data-table">
        <tr class="data-table-head"><th>Player Locations</th></tr>
        <tr class="bg1">
          <td>
            @if (Model.MemberLocations.Count > 0)
            {
              <div id="player-map" style="width:100%;height:300px;"></div>
            }
            else
            {
              <p style="padding:10px;margin:0;color:#888;">No location data available for clan members.</p>
            }
          </td>
        </tr>
      </table>
    </section>
  </div>

  @* Members table *@
  <div class="profile-section" style="margin-top:20px;">
    <h2>Members</h2>
    <table class="data-table">
      <tr class="data-table-head">
        <th style="text-align:right;">Rank</th>
        <th><a href="@(MemberSortUrl("name"))">Name@(MemberMark("name"))</a></th>
        <th style="text-align:center;"><a href="@(MemberSortUrl("mmrank"))">Rank@(MemberMark("mmrank"))</a></th>
        <th style="text-align:right;"><a href="@(MemberSortUrl("skill"))">Points@(MemberMark("skill"))</a></th>
        <th style="text-align:right;">Activity</th>
        <th style="text-align:right;"><a href="@(MemberSortUrl("time"))">Time@(MemberMark("time"))</a></th>
        <th style="text-align:right;"><a href="@(MemberSortUrl("kills"))">Kills@(MemberMark("kills"))</a></th>
        <th>Clan Kills</th>
        <th style="text-align:right;">%</th>
        <th style="text-align:right;"><a href="@(MemberSortUrl("deaths"))">Deaths@(MemberMark("deaths"))</a></th>
        <th style="text-align:right;"><a href="@(MemberSortUrl("kpd"))">K/D@(MemberMark("kpd"))</a></th>
      </tr>
      @{int rowNum = 0; int pageOffset = (Model.Members.Page - 1) * Model.Members.PageSize;}
      @foreach (var m in Model.Members.Items)
      {
        string rowClass = rowNum % 2 == 0 ? "bg1" : "bg2";
        rowNum++;
        <tr class="@rowClass">
          <td style="text-align:right;">@(pageOffset + rowNum)</td>
          <td>
            @if (!string.IsNullOrEmpty(m.Flag))
            {
              <img src="/hlstatsimg/flags/@(m.Flag.ToLowerInvariant()).gif" alt="@m.Country" title="@m.Country" style="vertical-align:middle;" />
            }
            <a asp-controller="Players" asp-action="Profile" asp-route-id="@m.PlayerId">@m.LastName</a>
          </td>
          <td style="text-align:center;">
            @if (m.RankImage != null)
            {
              <img src="/hlstatsimg/ranks/@(m.RankImage).png"
                   alt="@m.RankName" title="@(m.RankName ?? "")"
                   style="max-height:24px;vertical-align:middle;"
                   onerror="this.style.display='none'" />
            }
            @if (m.MmRank.HasValue)
            {
              <span style="font-size:0.85em;">@m.MmRank</span>
            }
          </td>
          <td style="text-align:right;">@m.Skill.ToString("N0")</td>
          <td style="text-align:right;">
            <activity-meter value="@m.ActivityScore" style="width:60px;" />
            @m.ActivityScore%
          </td>
          <td style="text-align:right;">@RazorHelpers.FormatTimeFull(m.ConnectionTime)</td>
          <td style="text-align:right;">@m.Kills.ToString("N0")</td>
          <td><activity-meter value="@m.ClanKillPercent" style="width:80px;" /></td>
          <td style="text-align:right;">@m.ClanKillPercent.ToString("F2")%</td>
          <td style="text-align:right;">@m.Deaths.ToString("N0")</td>
          <td style="text-align:right;">@m.KillDeathRatio.ToString("F2")</td>
        </tr>
      }
      @if (!Model.Members.Items.Any())
      {
        <tr><td colspan="11">No members.</td></tr>
      }
    </table>
    <partial name="_Pagination" model="@PaginationModel.From(Model.Members, p => Url.Action("Profile", new { id = Model.Clan.ClanId, membersPage = p, membersSortBy = Model.MembersSortBy, membersDesc = Model.MembersDescending })!)" />
  </div>

  <p style="margin-top:16px;font-size:0.9em;">Items marked * are generated from all recorded events.</p>
</div>

@* ══════════════════════════════════════════════════════ WEAPONS TAB *@
<div id="tab-weapons" class="tab-panel" style="display:none;">
  @if (!Model.WeaponUsage.Any())
  {
    <p>No weapon data available.</p>
  }
  else
  {
    <h2>Weapon Usage *</h2>
    <table class="data-table">
      <tr class="data-table-head">
        <th style="text-align:right;">Rank</th>
        <th><a href="@(WeaponSortUrl("name"))">Weapon@(WeaponMark("name"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("modifier"))">Points Modifier@(WeaponMark("modifier"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("kills"))">Kills@(WeaponMark("kills"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("killpct"))">% of Kills@(WeaponMark("killpct"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("headshots"))">Headshots@(WeaponMark("headshots"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("hspct"))">% of Headshots@(WeaponMark("hspct"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponSortUrl("hsperkill"))">HS/Kill@(WeaponMark("hsperkill"))</a></th>
      </tr>
      @{rowNum = 0;}
      @foreach (var w in Model.WeaponUsage)
      {
        string rowClass = rowNum % 2 == 0 ? "bg1" : "bg2";
        rowNum++;
        <tr class="@rowClass">
          <td style="text-align:right;">@rowNum</td>
          <td>
            <a asp-controller="Weapons" asp-action="Detail" asp-route-code="@(w.WeaponCode)" asp-route-game="@(Model.Game)">
              <img src="/hlstatsimg/games/@(Model.Game)/weapons/@(w.WeaponCode).gif"
                   alt="" title="@w.WeaponName"
                   style="vertical-align:middle;max-height:20px;"
                   onerror="this.style.display='none'" />
            </a>
          </td>
          <td style="text-align:right;">@w.Modifier.ToString("F2")</td>
          <td style="text-align:right;">@w.Kills.ToString("N0")</td>
          <td style="text-align:right;">@w.KillPercent.ToString("F2")%</td>
          <td style="text-align:right;">@w.Headshots.ToString("N0")</td>
          <td style="text-align:right;">@w.HeadshotPercent.ToString("F2")%</td>
          <td style="text-align:right;">@w.HeadshotsPerKill.ToString("F2")</td>
        </tr>
      }
    </table>
    <p style="margin-top:8px;font-size:0.9em;">* Generated from all recorded events.</p>
  }

  @if (Model.WeaponStats.Any())
  {
    <h2 style="margin-top:24px;">Weapon Stats *</h2>
    <table class="data-table">
      <tr class="data-table-head">
        <th style="text-align:right;">Rank</th>
        <th><a href="@(WeaponStatsSortUrl("name"))">Weapon@(WeaponStatsMark("name"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("shots"))">Shots@(WeaponStatsMark("shots"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("hits"))">Hits@(WeaponStatsMark("hits"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("damage"))">Damage@(WeaponStatsMark("damage"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("headshots"))">Headshots@(WeaponStatsMark("headshots"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("kills"))">Kills@(WeaponStatsMark("kills"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("kdr"))">K/D@(WeaponStatsMark("kdr"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("accuracy"))">Accuracy@(WeaponStatsMark("accuracy"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("dph"))">Dmg/Hit@(WeaponStatsMark("dph"))</a></th>
        <th style="text-align:right;"><a href="@(WeaponStatsSortUrl("spk"))">Shots/Kill@(WeaponStatsMark("spk"))</a></th>
      </tr>
      @{rowNum = 0;}
      @foreach (var w in Model.WeaponStats)
      {
        string rowClass = rowNum % 2 == 0 ? "bg1" : "bg2";
        rowNum++;
        <tr class="@rowClass">
          <td style="text-align:right;">@rowNum</td>
          <td>
            <a asp-controller="Weapons" asp-action="Detail" asp-route-code="@(w.WeaponCode)" asp-route-game="@(Model.Game)">
              <img src="/hlstatsimg/games/@(Model.Game)/weapons/@(w.WeaponCode).gif"
                   alt="" title="@w.WeaponName"
                   style="vertical-align:middle;max-height:20px;"
                   onerror="this.style.display='none'" />
            </a>
          </td>
          <td style="text-align:right;">@w.Shots.ToString("N0")</td>
          <td style="text-align:right;">@w.Hits.ToString("N0")</td>
          <td style="text-align:right;">@w.Damage.ToString("N0")</td>
          <td style="text-align:right;">@w.Headshots.ToString("N0")</td>
          <td style="text-align:right;">@w.Kills.ToString("N0")</td>
          <td style="text-align:right;">@w.KillDeathRatio.ToString("F2")</td>
