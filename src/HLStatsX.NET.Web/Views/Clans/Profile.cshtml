@model ClanProfileViewModel
@{
    ViewData["Title"] = Model.Clan.Name;
}

<h1>@Model.Clan.Tag &mdash; @Model.Clan.Name</h1>

<section class="clan-members">
    <h2>Members (@Model.Members.Count)</h2>
    <table class="stats-table">
        <thead>
            <tr>
                <th>Player</th>
                <th>Skill</th>
                <th>Kills</th>
                <th>Deaths</th>
                <th>K/D</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model.Members.OrderByDescending(p => p.Skill))
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(m.Flag))
                        {
                            <img src="/hlstatsimg/flags/@(m.Flag.ToLowerInvariant()).gif" alt="@m.Country" title="@m.Country" />
                        }
                        <a asp-controller="Players" asp-action="Profile" asp-route-id="@m.PlayerId">@m.LastName</a>
                    </td>
                    <td>@m.Skill</td>
                    <td>@m.Kills</td>
                    <td>@m.Deaths</td>
                    <td>@m.KillDeathRatio</td>
                </tr>
            }
            @if (!Model.Members.Any())
            {
                <tr><td colspan="5">No members.</td></tr>
            }
        </tbody>
    </table>
</section>
