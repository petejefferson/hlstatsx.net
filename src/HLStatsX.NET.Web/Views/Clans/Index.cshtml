@model ClanLeaderboardViewModel
@{
    ViewData["Title"] = "Clan Rankings";

    string SortUrl(string field)
    {
        bool nextDesc = Model.SortBy == field ? !Model.Descending : true;
        return Url.Action("Index", new { game = Model.Game, sortBy = field, desc = nextDesc })!;
    }
    string Mark(string field) => Model.SortBy == field ? (Model.Descending ? " ▼" : " ▲") : "";
}

<h1>Clan Rankings &mdash; @Model.Game</h1>

<table class="stats-table">
    <thead>
        <tr>
            <th>Rank</th>
            <th><a href="@(SortUrl("name"))">Clan@(Mark("name"))</a></th>
            <th>Tag</th>
            <th><a href="@(SortUrl("members"))">Members@(Mark("members"))</a></th>
            <th><a href="@(SortUrl("skill"))">Points@(Mark("skill"))</a></th>
        </tr>
    </thead>
    <tbody>
        @{ int rank = (Model.Clans.Page - 1) * Model.Clans.PageSize + 1; }
        @foreach (var clan in Model.Clans.Items)
        {
            <tr>
                <td>@rank</td>
                <td><a asp-action="Profile" asp-route-id="@clan.ClanId">@clan.Name</a></td>
                <td>@clan.Tag</td>
                <td>@clan.Players.Count</td>
                <td>@clan.Players.Where(p => p.HideRanking == 0).Sum(p => p.Skill).ToString("N0")</td>
            </tr>
            rank++;
        }
    </tbody>
</table>

<partial name="_Pagination" model="@PaginationModel.From(Model.Clans, p => Url.Action("Index", new { game = Model.Game, sortBy = Model.SortBy, desc = Model.Descending, page = p })!)" />
